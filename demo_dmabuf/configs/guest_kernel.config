#
# Kernel config fragment for DMA-BUF demo
#
# Apply with: scripts/config --file .config --set-val <key> <val>
# or merge into a defconfig before building the guest kernel.
#

# DMA-BUF core
CONFIG_DMA_SHARED_BUFFER=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_DEBUG=y

# Sync-file support (implicit sync)
CONFIG_SYNC_FILE=y

# Module loading (needed for our .ko files)
CONFIG_MODULES=y
CONFIG_MODULE_FORCE_LOAD=y
CONFIG_MODULE_UNLOAD=y

# Debug filesystem (useful for inspecting dma-buf state)
CONFIG_DEBUG_FS=y

# Skip module signing so we can load our test modules easily
CONFIG_MODULE_SIG=n

# Identifiable kernel build
CONFIG_LOCALVERSION="-dmabuf-demo"
